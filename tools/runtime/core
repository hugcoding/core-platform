#!/bin/sh
set -eu

PROJECT_ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)
cd "$PROJECT_ROOT"

show_help() {
    printf '%s\n' ""
    printf '%s\n' "CORE CLI"
    printf '%s\n' ""
    printf '%s\n' "Usage:"
    printf '%s\n' "  core doctor"
    printf '%s\n' "  core docs generate"
    printf '%s\n' "  core docs serve"
    printf '%s\n' "  core docs build"
    printf '%s\n' "  core docs open"
    printf '%s\n' "  core project analyze"
    printf '%s\n' "  core project export"
    printf '%s\n' "  core jira auth"
    printf '%s\n' "  core jira epics --project SCRUM --dry-run"
    printf '%s\n' "  core jira stories --project SCRUM --dry-run"
    printf '%s\n' "  core jira sync --project SCRUM --dry-run"
    printf '%s\n' "  core cleanup assess"
    printf '%s\n' "  core cleanup legacy-duplicates --dry-run"
    printf '%s\n' "  core runtime status"
    printf '%s\n' "  core runtime health"
    printf '%s\n' "  core runtime logs"
    printf '%s\n' "  core runtime dlq"
    printf '%s\n' "  core runtime cleanlocks"
    printf '%s\n' "  core runtime watch"
    printf '%s\n' "  core runtime start"
    printf '%s\n' "  core runtime stop"
    printf '%s\n' "  core runtime restart"
    printf '%s\n' "  core git status"
    printf '%s\n' "  core git push"
    printf '%s\n' "  core version"
    printf '%s\n' ""
}

command_domain="${1:-}"
command_action="${2:-}"

case "$command_domain" in
    doctor)
        python3 -m core.cli doctor
        ;;
    docs)
        case "$command_action" in
            generate)
                ./gendocs
                ;;
            serve|build|open)
                python3 -m core.cli docs "$command_action"
                ;;
            *)
                echo "Unknown docs command."
                echo "Use: core docs generate | serve | build | open"
                exit 1
                ;;
        esac
        ;;
    project)
        case "$command_action" in
            analyze)
                ./genproject
                ;;
            export)
                ./genproject
                echo ""
                echo "Exports generated in project/exports"
                ;;
            *)
                echo "Unknown project command."
                echo "Use: core project analyze | export"
                exit 1
                ;;
        esac
        ;;
    jira)
        shift
        python3 -m core.cli jira "$@"
        ;;
    cleanup)
        case "$command_action" in
            assess)
                sh ./tools/runtime/legacy-assessment
                ;;
            legacy-duplicates)
                sh ./tools/runtime/legacy-duplicates "${3:-}"
                ;;
            *)
                echo "Unknown cleanup command."
                echo "Use: core cleanup assess | legacy-duplicates --dry-run"
                exit 1
                ;;
        esac
        ;;
    runtime)
        case "$command_action" in
            status)
                ./tools/runtime/status
                ;;
            health)
                ./tools/runtime/health
                ;;
            logs)
                ./tools/runtime/logs
                ;;
            dlq)
                sh ./tools/runtime/dlq
                ;;
            cleanlocks)
                ./tools/runtime/cleanlocks
                ;;
            watch)
                ./tools/runtime/watch
                ;;
            start)
                docker compose up -d
                ;;
            stop)
                docker compose down
                ;;
            restart)
                docker compose down && docker compose up -d
                ;;
            *)
                echo "Unknown runtime command."
                echo "Use: core runtime status | health | logs | dlq | cleanlocks | watch | start | stop | restart"
                exit 1
                ;;
        esac
        ;;
    git)
        case "$command_action" in
            status)
                git status
                ;;
            push)
                git push
                ;;
            *)
                echo "Unknown git command."
                echo "Use: core git status | push"
                exit 1
                ;;
        esac
        ;;
    version)
        if [ -f version.json ]; then
            cat version.json
        else
            echo "version.json not found"
            exit 1
        fi
        ;;
    *)
        show_help
        ;;
esac
